# Configuración del Servidor
PORT=8080

# Configuración de Google Cloud / Firebase
GOOGLE_CLOUD_PROJECT=rebideo-dev
# Para desarrollo local con emuladores
FIRESTORE_EMULATOR_HOST=127.0.0.1:8082
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
STORAGE_EMULATOR_HOST=http://127.0.0.1:4443
PUBSUB_EMULATOR_HOST=127.0.0.1:8085

# Buckets de Google Cloud Storage
GCS_RAW_BUCKET=rebideo-raw-videos
GCS_PROCESSED_BUCKET=rebideo-processed-videos
